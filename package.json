{
  "name": "swarm-mcp",
  "version": "0.9.5",
  "main": "dist/index.js",
  "bin": {
    "swarm-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "npm run build:server && npm run build:ui",
    "build:server": "tsc",
    "build:ui": "cd public/open-app && INPUT=mcp-app.html vite build",
    "start": "npm run start:stdio",
    "start:stdio": "node dist/index.js",
    "start:web": "node dist/web.js",
    "dev": "nodemon --exec ts-node src/index.ts",
    "serve": "ts-node src/index.ts",
    "serve:web": "ts-node src/web.ts",
    "test": "jest"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "@ethereumjs/wallet": "^10.0.0",
    "@ethersphere/bee-js": "^10.1.1",
    "@modelcontextprotocol/ext-apps": "^1.0.1",
    "@modelcontextprotocol/sdk": "^1.26.0",
    "dotenv": "^17.2.3",
    "open": "^11.0.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/mime-types": "^3.0.1",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "jest": "^30.0.3",
    "nodemon": "^3.1.10",
    "ts-jest": "^29.4.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^5.4.11",
    "vite-plugin-singlefile": "^2.3.0"
  }
